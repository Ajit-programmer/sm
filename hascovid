import pandas as pd
import re
from collections import Counter
import matplotlib.pyplot as plt
df = pd.read_csv("covid19_tweets.csv")
hashtags = []
for i in df['text'].dropna():
    tags = re.findall(r"#(\w+)", i)
    hashtags.extend(tags)
top = Counter(hashtags).most_common(10)
tag_df = pd.DataFrame(top, columns=['Hashtag', 'Count'])
print(tag_df)
plt.bar(tag_df['Hashtag'], tag_df['Count'])
plt.xticks(rotation=90)
plt.show()
